# =============================================================================
# Krishi-Mitra — single repo-wide .gitignore (root)
# =============================================================================

# --- Environment & secrets ---
.env
.env.*
!.env.example
backend/.env

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# --- Virtual environments ---
venv/
env/
.venv/

# --- IDE & OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- ML weights & exports (large binaries) ---
weights/
*.pt
*.pth

# Ignore ONNX by default; allow committed hackathon models under agent
*.onnx
!backend/agent/model/
!backend/agent/model/*.onnx
*.onnx
backend/agent/model/

# --- Datasets ---
plantvillage/
plantvillage_subset/

# --- YOLO / training outputs ---
runs/

# --- Uploads & notebook checkpoints ---
uploads/
.ipynb_checkpoints/
scripts/.ipynb_checkpoints/

# --- Local tooling ---
ngrok.exe

# --- Scratch / test images (remove or narrow if you ship real assets) ---
*.jpg
*.png
*.jpeg
